{
  "name": "show-tracker",
  "version": "1.0.0",
  "description": "A personal show tracker designed to help users manage their entertainment consumption.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "server": "json-server --watch server/db.json --port 3001",
    "reset-db": "cp db.seed.json server/db.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "json-server": "^0.17.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Donna-Sayos/show-tracker.git"
  },
  "author": "Donna Sayos",
  "license": "ISC"
}
